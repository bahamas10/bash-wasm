$PRODUCES web.c
#include <config.h>

#if defined (HAVE_UNISTD_H)
#  include <unistd.h>
#endif

#include "../bashansi.h"

#include <stdio.h>
#include "../shell.h"

#include "common.h"

$BUILTIN web
$FUNCTION web_builtin
$SHORT_DOC web ...
Go from bash into the web / dom manipulation

Exit Status:
Returns success unless a write error occurs.
$END

#include <emscripten.h>

EM_JS(int, bash_web, (int argc, char **argv), {
	const args = [];
	for (let i = 0; i < argc; i++) {
		args.push(UTF8ToString(HEAP32[(argv >> 2) + i]));
	}

	return globalThis.__bash_web_internal(args);
});

int
web_builtin (WORD_LIST *list)
{
	if (list == NULL) {
		builtin_usage();
		return EX_USAGE;
	}

	// loop the arguments, put them into an array
	int argc = 0;
	WORD_LIST *node;
	for (node = list; node != NULL; node = node->next) {
		argc++;
	}

	char **argv = xmalloc(argc * sizeof (char *));

	int i = 0;
	for (node = list; node != NULL; node = node->next) {
		argv[i++] = savestring(node->word->word);
	}

	// call into javascript with the arguments
	int status = bash_web(argc, argv);

	// free any arguments that have been allocated
	for (i = 0; i < argc; i++) {
		free(argv[i]);
	}
	free(argv);

	return status;
}
